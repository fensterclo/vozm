-- GUI ДЛЯ ИНЖЕКТОРА (красивая версия)

local linkText = "https://go.linkify.ru/2HTS"

-- Создаём ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CustomLinkGUI"
screenGui.Parent = game:GetService("CoreGui")

-- Основное окно (с закруглёнными углами)
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 400, 0, 250)
mainFrame.Position = UDim2.new(0.5, -200, 0.5, -125)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
mainFrame.BackgroundTransparency = 0.1
mainFrame.BorderSizePixel = 0
mainFrame.ClipsDescendants = true -- Важно для закругления!
mainFrame.Parent = screenGui

-- Закругление углов через UICorner
local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 20)
uiCorner.Parent = mainFrame

-- Заголовок (один цвет текста)
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -40, 0, 60)
title.Position = UDim2.new(0, 20, 0, 20)
title.BackgroundTransparency = 1
title.Text = "Get Script in Link!"
title.TextColor3 = Color3.fromRGB(220, 220, 255)
title.TextScaled = true
title.Font = Enum.Font.FredokaOne -- Красивый современный шрифт
title.Parent = mainFrame

-- Кнопка Copy Link
local copyBtn = Instance.new("TextButton")
copyBtn.Size = UDim2.new(0, 220, 0, 55)
copyBtn.Position = UDim2.new(0.5, -110, 0, 100)
copyBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
copyBtn.BackgroundTransparency = 0.3
copyBtn.BorderSizePixel = 0
copyBtn.Text = "Copy Link!"
copyBtn.TextColor3 = Color3.fromRGB(220, 220, 255)
copyBtn.TextScaled = true
copyBtn.Font = Enum.Font.FredokaOne
copyBtn.Parent = mainFrame

-- Закругление углов кнопки
local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 12)
btnCorner.Parent = copyBtn

-- Нижний текст
local loveText = Instance.new("TextLabel")
loveText.Size = UDim2.new(1, -40, 0, 50)
loveText.Position = UDim2.new(0, 20, 0, 180)
loveText.BackgroundTransparency = 1
loveText.Text = "We love you! ❤️"
loveText.TextColor3 = Color3.fromRGB(220, 220, 255)
loveText.TextScaled = true
loveText.Font = Enum.Font.FredokaOne
loveText.Parent = mainFrame

-- Кнопка закрытия (крестик)
local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 32, 0, 32)
closeBtn.Position = UDim2.new(1, -42, 0, 10)
closeBtn.BackgroundTransparency = 1
closeBtn.Text = "✕"
closeBtn.TextColor3 = Color3.fromRGB(220, 220, 255)
closeBtn.TextScaled = true
closeBtn.Font = Enum.Font.FredokaOne
closeBtn.Parent = mainFrame

-- Эффект наведения на кнопку
copyBtn.MouseEnter:Connect(function()
    copyBtn.BackgroundTransparency = 0.1
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
end)
copyBtn.MouseLeave:Connect(function()
    copyBtn.BackgroundTransparency = 0.3
    copyBtn.TextColor3 = Color3.fromRGB(220, 220, 255)
end)

-- Эффект наведения на крестик
closeBtn.MouseEnter:Connect(function()
    closeBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
end)
closeBtn.MouseLeave:Connect(function()
    closeBtn.TextColor3 = Color3.fromRGB(220, 220, 255)
end)

-- Копирование ссылки
copyBtn.MouseButton1Click:Connect(function()
    if setclipboard then
        setclipboard(linkText)
        copyBtn.Text = "✅ Copied!"
        task.wait(1.5)
        copyBtn.Text = "Copy Link!"
    else
        copyBtn.Text = "❌ No clipboard"
        task.wait(1)
        copyBtn.Text = "Copy Link!"
    end
end)

-- Закрытие GUI
closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

-- Перетаскивание окна
local dragging = false
local dragInput, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Плавное появление
mainFrame.BackgroundTransparency = 0.5
for i = 0.5, 0.1, -0.05 do
    mainFrame.BackgroundTransparency = i
    task.wait(0.02)
end

print("✅ GUI загружен! Нажми на крестик, чтобы закрыть.")
